// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum CaseStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  CHECKING
  QUERY_RAISED
  APPROVED
  REJECTED
}

enum AUTH_METHOD {
  PASSWORD
  EMAIL_OTP
  GOOGLE
}

enum LoginChannel {
  WEB
  MOBILE
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  INDUSTRIAL
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
}

enum QueryType {
  TO_ENGINEER
  TO_BANK
}

enum QueryStatus {
  OPEN
  RESPONDED
  RESOLVED
}

model Role {
  id           String       @id @default(uuid())
  name         String       @unique
  description  String?
  loginChannel LoginChannel
  isSystem     Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users            User[]
  rolePermissions  RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}
model InstitutionType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  institutions Institution[]
}

model Institution {
  id                String   @id @default(uuid())
  name              String
  code              String   @unique
  institutionTypeId String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  institutionType InstitutionType @relation(fields: [institutionTypeId], references: [id])
  branches        Branch[]
  users           User[]
  cases           Case[]

  @@index([institutionTypeId])
}

model Branch {
  id                String    @id @default(uuid())
  institutionId     String
  branchName        String
  ifscCode          String?   @unique
  city              String
  state             String
  district          String?
  address           String?
  isManuallyEntered Boolean   @default(false)
  needsVerification Boolean   @default(false)
  verifiedAt        DateTime?
  verifiedById      String?
  createdAt         DateTime  @default(now())

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  verifiedBy  User?       @relation("BranchVerifiedBy", fields: [verifiedById], references: [id])
  users       User[]
  cases       Case[]

  @@index([institutionId])
  @@index([city])
  @@index([needsVerification])
  @@unique([institutionId, branchName, city])
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  mobile       String?      @unique
  passwordHash String?
  googleId     String?      @unique
  authMethod   AUTH_METHOD?
  roleId       String
  isActive     Boolean      @default(true)
  isApproved   Boolean      @default(false)
  institutionId String?
  branchId      String?
  fcmToken     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  institution       Institution?       @relation(fields: [institutionId], references: [id])
  branch            Branch?            @relation(fields: [branchId], references: [id])
  verifiedBranches  Branch[]           @relation("BranchVerifiedBy")
  role              Role               @relation(fields: [roleId], references: [id])
  engineerLocations EngineerLocation[]
  createdCases      Case[]             @relation("CreatedBy")
  assignedCases     Case[]             @relation("AssignedTo")
  checkedCases      Case[]             @relation("CheckedBy")
  uploadedDocuments Document[]
  valuationReports  ValuationReport[]
  raisedQueries     Query[]            @relation("RaisedBy")
  receivedQueries   Query[]            @relation("DirectedTo")
  queryResponses    QueryResponse[]
  auditLogs         CaseAuditLog[]
  feeCollections    FeeCollection[]
}

model EngineerLocation {
  id         String   @id @default(uuid())
  engineerId String
  city       String
  state      String
  createdAt  DateTime @default(now())

  engineer User @relation(fields: [engineerId], references: [id], onDelete: Cascade)

  @@unique([engineerId, city]) // unique constraint for engineer and city
  @@index([city]) // index for city search
}

model Case {
  id               String       @id @default(uuid())
  caseNumber       String       @unique
  status           CaseStatus   @default(PENDING)
  institutionId    String
  branchId         String?
  createdById      String
  assignedToId     String?
  checkedById      String?
  customerName     String
  customerMobile   String
  propertyLocation String?
  propertyType     PropertyType
  bankReference    String? // Bank's own loan/case number
  assignedAt       DateTime?
  submittedAt      DateTime?
  approvedAt       DateTime?
  deadline         DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  institution   Institution      @relation(fields: [institutionId], references: [id])
  branch        Branch?          @relation(fields: [branchId], references: [id])
  createdBy     User             @relation("CreatedBy", fields: [createdById], references: [id])
  assignedTo    User?            @relation("AssignedTo", fields: [assignedToId], references: [id])
  checkedBy     User?            @relation("CheckedBy", fields: [checkedById], references: [id])
  documents     Document[]
  report        ValuationReport?
  auditLogs     CaseAuditLog[]
  queries       Query[]
  feeCollection FeeCollection?

  @@index([status])
  @@index([institutionId])
  @@index([branchId])
  @@index([assignedToId])
  @@index([createdAt])
}

model Document {
  id           String   @id @default(uuid())
  caseId       String
  uploadedById String
  fileName     String
  fileType     String
  s3Key        String
  fileSize     Int
  docType      String // 'bank_doc' | 'site_photo' | 'valuation_report'
  createdAt    DateTime @default(now())

  case       Case @relation(fields: [caseId], references: [id])
  uploadedBy User @relation(fields: [uploadedById], references: [id])
}

model ValuationReport {
  id                  String    @id @default(uuid())
  caseId              String    @unique
  engineerId          String
  plotArea            Float?
  builtUpArea         Float?
  floors              Int?
  constructionAge     Int?
  constructionQuality String?
  marketValue         Decimal?  @db.Decimal(15, 2)
  distressValue       Decimal?  @db.Decimal(15, 2)
  recommendedLoan     Decimal?  @db.Decimal(15, 2)
  engineerNotes       String?
  visitLat            Float?
  visitLng            Float?
  visitStartedAt      DateTime?
  visitEndedAt        DateTime?
  checkerNotes        String?
  checkerStatus       String? // 'pending' | 'approved' | 'rejected'
  reportPdfS3Key      String?
  submittedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  case     Case @relation(fields: [caseId], references: [id])
  engineer User @relation(fields: [engineerId], references: [id])
}

model FeeCollection {
  id                 String      @id @default(uuid())
  caseId             String      @unique
  engineerId         String
  standardFee        Decimal     @db.Decimal(10, 2)
  collectedAmount    Decimal     @db.Decimal(10, 2)
  paymentMode        PaymentMode
  utrNumber          String? // for UPI
  receiptPhotoS3Key  String? // for cash
  customerConfirmed  Boolean     @default(false)
  discrepancyFlagged Boolean     @default(false)
  discrepancyAmount  Decimal?    @db.Decimal(10, 2)
  notes              String?
  collectedAt        DateTime?
  createdAt          DateTime    @default(now())

  case     Case @relation(fields: [caseId], references: [id])
  engineer User @relation(fields: [engineerId], references: [id])
}

model Query {
  id           String      @id @default(uuid())
  caseId       String
  raisedById   String
  directedToId String
  queryType    QueryType
  message      String
  status       QueryStatus @default(OPEN)
  resolvedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  case       Case            @relation(fields: [caseId], references: [id])
  raisedBy   User            @relation("RaisedBy", fields: [raisedById], references: [id])
  directedTo User            @relation("DirectedTo", fields: [directedToId], references: [id])
  responses  QueryResponse[]
}

model QueryResponse {
  id            String   @id @default(uuid())
  queryId       String
  respondedById String
  message       String
  attachments   String[] // S3 keys
  createdAt     DateTime @default(now())

  query       Query @relation(fields: [queryId], references: [id], onDelete: Cascade)
  respondedBy User  @relation(fields: [respondedById], references: [id])
}

model CaseAuditLog {
  id        String   @id @default(uuid())
  caseId    String
  actorId   String
  action    String
  oldStatus String?
  newStatus String?
  notes     String?
  createdAt DateTime @default(now())

  case  Case @relation(fields: [caseId], references: [id])
  actor User @relation(fields: [actorId], references: [id])
}
